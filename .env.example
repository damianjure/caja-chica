# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=YOUR_TELEGRAM_BOT_USERNAME
TELEGRAM_WEBHOOK_SECRET=

# Supabase Configuration (client)
VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Supabase Configuration (server)
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# API / Dashboard Configuration
VITE_API_URL=http://localhost:8080
ALLOWED_ORIGINS=https://caja-chica-bot.web.app,http://localhost:5173
DASHBOARD_URL=http://localhost:5173

# Dangerous route hardening (disabled by default)
ENABLE_DANGEROUS_ROUTES=false
ADMIN_API_TOKEN=

# Cron endpoints shared secret — required for /api/crons/* (fail-closed if absent)
# Generate: openssl rand -base64 32
# Cloud Scheduler jobs must send this in header X-Cron-Secret
CRON_SECRET=

# Gemini API Key
GEMINI_API_KEY=

# Google Drive (OAuth — owners connect Drive for report uploads)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=
# Generate: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Email (Brevo) — enables invitation emails (graceful fallback if absent)
BREVO_API_KEY=
FROM_EMAIL=hola@damianjure.com
FROM_NAME=Caja Chica

# Runtime
PORT=8080
NODE_ENV=development

# Bootstrap note:
# 1. Run supabase_schema.sql
# 2. Insert your email into public.bootstrap_admin_emails
# 3. Configure Supabase Before User Created hook to public.hook_authorize_google_invited_users