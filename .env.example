# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=YOUR_TELEGRAM_BOT_USERNAME

# Supabase Configuration (client)
VITE_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Supabase Configuration (server)
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# API / Dashboard Configuration
VITE_API_URL=http://localhost:8080
ALLOWED_ORIGINS=https://balancediario.web.app,http://localhost:5173
DASHBOARD_URL=http://localhost:5173

# Dangerous route hardening (disabled by default)
ENABLE_DANGEROUS_ROUTES=false
ADMIN_API_TOKEN=

# Gemini API Key
GEMINI_API_KEY=

# Bootstrap note:
# 1. Run supabase_schema.sql
# 2. Insert your email into public.bootstrap_admin_emails
# 3. Configure Supabase Before User Created hook to public.hook_authorize_google_invited_users
